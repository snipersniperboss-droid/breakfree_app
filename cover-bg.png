import { useEffect, useRef, useState } from 'react';
import { Link, useNavigate, useParams } from 'react-router-dom';
import { CHAT_ROOMS, AMBIENT_MESSAGES, SEED_MEMBERS, QUICK_REPLIES } from '../data/community';
import { useApp } from '../state/store';
import { AvatarBubble } from '../components/AvatarBubble';

export default function PeerChat() {
  const navigate = useNavigate();
  return (
    <div className="app-bg min-h-full pb-28 px-4 pt-5">
      <div className="flex items-center gap-3 mb-1">
        <Link to="/support" className="text-ink-300 hover:text-white text-xl">←</Link>
        <h1 className="font-display text-2xl font-bold text-white leading-tight">Peer chat</h1>
      </div>
      <p className="text-ink-300 text-sm mb-5 ml-9">
        Topic rooms. Real people, real time.
      </p>

      <div className="space-y-3">
        {CHAT_ROOMS.map((r) => (
          <button
            key={r.id}
            onClick={() => navigate(`/support/chat/${r.id}`)}
            className="w-full glass rounded-3xl p-4 text-left hover:bg-white/[0.04] transition flex items-center gap-3"
          >
            <div className="w-12 h-12 rounded-2xl bg-gradient-to-br from-sage-400/30 to-sage-700/30 flex items-center justify-center text-2xl flex-shrink-0 border border-sage-500/20">
              {r.icon}
            </div>
            <div className="flex-1 min-w-0">
              <div className="flex items-center gap-2 mb-0.5">
                <div className="text-white font-semibold truncate">{r.name}</div>
                <span className="chip !py-0 !px-2 text-[9px]">
                  <span className="w-1.5 h-1.5 rounded-full bg-sage-400 pulse-soft" />
                  {r.onlineNow} online
                </span>
              </div>
              <div className="text-xs text-ink-300 leading-relaxed line-clamp-2">{r.description}</div>
            </div>
            <div className="text-sage-300 text-lg">→</div>
          </button>
        ))}
      </div>

      <div className="text-[10px] text-ink-400 text-center mt-6 leading-relaxed">
        Messages are not end-to-end encrypted. Don\'t share identifying info.
        <br />Be kind. Report what\'s off.
      </div>
    </div>
  );
}

export function ChatRoom() {
  const { id } = useParams<{ id: string }>();
  const room = CHAT_ROOMS.find((r) => r.id === id);
  const {
    state, days, theme, addPeerMessage, toggleBlockMember, reportPeerMessage,
  } = useApp();
  const [input, setInput] = useState('');
  const [menuMsgId, setMenuMsgId] = useState<string | null>(null);
  const scrollerRef = useRef<HTMLDivElement>(null);

  const roomId = id ?? 'r_general';
  const messages = state.peerMessages[roomId] ?? [];
  const blocked = new Set(state.blockedMembers);

  // Seed ambient messages on first entry
  useEffect(() => {
    if (!room || messages.length > 0) return;
    const seed = AMBIENT_MESSAGES[room.id] ?? [];
    const now = Date.now();
    seed.forEach((m, i) => {
      // Stagger by minutesAgo so they appear in chronological order
      const at = new Date(now - m.minutesAgo * 60_000).toISOString();
      setTimeout(() => {
        addPeerMessage({
          id: `seed-${room.id}-${i}`,
          roomId: room.id,
          memberId: m.memberId,
          text: m.text,
          at,
        });
      }, i * 50);
    });
    // eslint-disable-next-line react-hooks/exhaustive-deps
  }, [room?.id]);

  // Periodically drip in new messages
  useEffect(() => {
    if (!room) return;
    const interval = setInterval(() => {
      const pool = AMBIENT_MESSAGES[room.id] ?? AMBIENT_MESSAGES.r_general;
      if (!pool || pool.length === 0) return;
      const m = pool[Math.floor(Math.random() * pool.length)];
      // Skip if last message from same member was recent
      const last = messages[messages.length - 1];
      if (last?.memberId === m.memberId) return;
      addPeerMessage({
        id: crypto.randomUUID(),
        roomId: room.id,
        memberId: m.memberId,
        text: m.text,
        at: new Date().toISOString(),
      });
    }, 18000 + Math.random() * 12000);
    return () => clearInterval(interval);
  }, [room?.id, messages.length]);

  // Auto-scroll
  useEffect(() => {
    scrollerRef.current?.scrollTo({ top: scrollerRef.current.scrollHeight, behavior: 'smooth' });
  }, [messages.length]);

  if (!room) {
    return (
      <div className="app-bg min-h-full flex items-center justify-center p-6 text-center">
        <div>
          <div className="text-2xl mb-2">Room not found</div>
          <Link to="/support/chat" className="btn-primary inline-block mt-3">Back to rooms</Link>
        </div>
      </div>
    );
  }

  const send = (textArg?: string) => {
    const text = (textArg ?? input).trim();
    if (!text) return;
    addPeerMessage({
      id: crypto.randomUUID(),
      roomId: room.id,
      memberId: 'me',
      text,
      at: new Date().toISOString(),
    });
    setInput('');
  };

  const onlineMembers = SEED_MEMBERS.filter((m) => m.online && !blocked.has(m.id)).slice(0, 5);

  return (
    <div className="app-bg min-h-full flex flex-col">
      {/* Header */}
      <div className="px-4 pt-5 pb-3 safe-top">
        <div className="flex items-center gap-3 mb-1">
          <Link to="/support/chat" className="text-ink-300 hover:text-white text-xl">←</Link>
          <div className="text-2xl">{room.icon}</div>
          <div className="flex-1 min-w-0">
            <div className="text-white font-semibold leading-tight">{room.name}</div>
            <div className="text-[10px] text-sage-300 uppercase tracking-widest flex items-center gap-1.5">
              <span className="w-1.5 h-1.5 rounded-full bg-sage-400 pulse-soft" />
              {room.onlineNow} online
            </div>
          </div>
        </div>
        <div className="text-[11px] text-ink-300 ml-9 leading-relaxed">{room.description}</div>
      </div>

      {/* Online members strip */}
      <div className="px-4 mb-3">
        <div className="flex gap-2 overflow-x-auto -mx-1 px-1 pb-1 scrollbar-thin">
          {onlineMembers.map((m) => (
            <div key={m.id} className="flex flex-col items-center gap-1 flex-shrink-0">
              <AvatarBubble days={m.days} theme={m.theme} size={36} online={true} />
              <div className="text-[9px] text-ink-300 max-w-[44px] truncate">{m.name}</div>
            </div>
          ))}
        </div>
      </div>

      {/* Messages */}
      <div ref={scrollerRef} className="flex-1 overflow-y-auto px-4 pb-44 space-y-3">
        {messages.length === 0 && (
          <div className="text-center text-ink-400 text-sm py-10">
            Be the first to say something kind 💚
          </div>
        )}
        {messages.map((m) => {
          const isMe = m.memberId === 'me';
          const sender = !isMe ? SEED_MEMBERS.find((x) => x.id === m.memberId) : null;
          if (sender && blocked.has(sender.id)) return null;
          return (
            <div key={m.id} className={`flex items-start gap-2 animate-floatUp ${isMe ? 'flex-row-reverse' : ''}`}>
              {sender ? (
                <AvatarBubble days={sender.days} theme={sender.theme} size={32} online={sender.online} />
              ) : (
                <AvatarBubble days={days} theme={theme} size={32} ring="#43c486" />
              )}
              <div className={`flex-1 min-w-0 ${isMe ? 'flex flex-col items-end' : ''}`}>
                {!isMe && (
                  <div className="text-[10px] text-ink-300 mb-0.5 flex items-center gap-1.5">
                    <span>{sender?.name}</span>
                    {sender && (
                      <span className="text-ink-400">d{sender.days}</span>
                    )}
                  </div>
                )}
                <div
                  className={`relative inline-block max-w-[78%] rounded-2xl px-3.5 py-2 text-sm leading-relaxed ${
                    isMe
                      ? 'bg-sage-600/30 text-white border border-sage-500/30 rounded-br-sm'
                      : 'glass text-ink-100 rounded-bl-sm'
                  }`}
                  onDoubleClick={() => setMenuMsgId(m.id)}
                >
                  {m.text}
                </div>
                <div className="text-[9px] text-ink-400 mt-0.5 px-1">
                  {timeOf(m.at)}
                </div>
                {menuMsgId === m.id && (
                  <div
                    className="absolute mt-1 glass-strong rounded-xl p-1 z-10 shadow-soft"
                    style={isMe ? { right: 0 } : { left: 0 }}
                    onClick={(e) => e.stopPropagation()}
                  >
                    {!isMe && sender && (
                      <>
                        <MenuBtn onClick={() => { toggleBlockMember(sender.id); setMenuMsgId(null); }}>
                          🚫 Block {sender.name}
                        </MenuBtn>
                        <MenuBtn onClick={() => { reportPeerMessage(m.id); setMenuMsgId(null); }}>
                          ⚠️ Report message
                        </MenuBtn>
                      </>
                    )}
                    <MenuBtn onClick={() => setMenuMsgId(null)}>✕ Close</MenuBtn>
                  </div>
                )}
              </div>
            </div>
          );
        })}
      </div>

      {/* Quick replies */}
      <div className="fixed bottom-32 left-0 right-0 px-3 z-10">
        <div className="max-w-md mx-auto">
          <div className="flex gap-1.5 overflow-x-auto pb-1.5 -mx-1 px-1 scrollbar-thin">
            {QUICK_REPLIES.slice(0, 6).map((r) => (
              <button
                key={r}
                onClick={() => send(r)}
                className="whitespace-nowrap text-[11px] glass rounded-full px-3 py-1 text-sage-200 hover:bg-white/10 transition flex-shrink-0"
              >
                {r}
              </button>
            ))}
          </div>
        </div>
      </div>

      {/* Composer */}
      <div className="fixed bottom-16 left-0 right-0 px-3 pb-3 safe-bottom z-10">
        <div className="max-w-md mx-auto">
          <div className="glass-strong rounded-2xl p-1.5 flex items-end gap-2">
            <textarea
              value={input}
              onChange={(e) => setInput(e.target.value)}
              onKeyDown={(e) => {
                if (e.key === 'Enter' && !e.shiftKey) {
                  e.preventDefault();
                  send();
                }
              }}
              placeholder="Be kind. Be brief. Be real."
              rows={1}
              className="flex-1 bg-transparent text-white placeholder:text-ink-400 px-3 py-2.5 text-sm resize-none focus:outline-none max-h-32"
            />
            <button
              onClick={() => send()}
              disabled={!input.trim()}
              className="btn-primary !rounded-xl !px-3 !py-2 disabled:opacity-30"
              aria-label="Send"
            >
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
                <path d="M5 12 L19 12 M13 6 L19 12 L13 18" stroke="currentColor" strokeWidth="2.2" strokeLinecap="round" strokeLinejoin="round" />
              </svg>
            </button>
          </div>
        </div>
      </div>
    </div>
  );
}

function MenuBtn({ children, onClick }: { children: React.ReactNode; onClick?: () => void }) {
  return (
    <button
      onClick={onClick}
      className="block w-full text-left text-xs text-white px-3 py-1.5 rounded-lg hover:bg-white/10"
    >
      {children}
    </button>
  );
}

function timeOf(iso: string): string {
  const d = new Date(iso);
  const now = new Date();
  const sameDay = d.toDateString() === now.toDateString();
  if (sameDay) {
    return d.toLocaleTimeString(undefined, { hour: 'numeric', minute: '2-digit' });
  }
  return d.toLocaleDateString(undefined, { month: 'short', day: 'numeric' });
}
